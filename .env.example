# 盐阜配送平台 - 环境变量配置
NODE_ENV=production
PORT=3000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=kuailv
DB_PASSWORD=your_database_password_here
DB_NAME=kuailv

# JWT配置
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=259200
JWT_REFRESH_EXPIRES_IN=604800

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=500
RATE_LIMIT_AUTH_MAX_REQUESTS=200

# 高德地图 API（可选，不配置则距离计算回退到 Haversine 公式）
# AMAP_REST_KEY=
# AMAP_PRIVATE_KEY=

# AI模块数据库配置（与主数据库相同）
YANFU_DB_HOST=localhost
YANFU_DB_PORT=3306
YANFU_DB_USER=kuailv
YANFU_DB_PASSWORD=[DBCONFIG]
YANFU_DB_NAME=kuailv
YANFU_DB_CONNECTION_LIMIT=10

---

